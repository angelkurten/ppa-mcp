# Token personal de la API de ClickUp (ClickUp → Settings → Apps → API Token, empieza con pk_)
CLICKUP_TOKEN=pk_xxxxxxxx
# Secreto de acceso al endpoint MCP (mínimo 16 chars; genera uno con: openssl rand -hex 24)
PPA_SECRET=
# Puerto local (Caddy hace proxy a este puerto)
PORT=5071
# IDs de tus listas en ClickUp (visibles en la URL de cada lista)
INBOX_LIST_ID=
TAREAS_LIST_ID=
